{
  "name": "@threlte/core",
  "version": "8.5.1",
  "author": "Grischa Erbe <hello@legrisch.com> (https://legrisch.com)",
  "license": "MIT",
  "description": "A 3D framework for the web, built on top of Svelte and Three.js",
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@sveltejs/adapter-auto": "^6.1.0",
    "@sveltejs/kit": "^2.37.0",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^6.1.4",
    "@threlte/test": "^1.0.0",
    "@types/bun": "^1.2.12",
    "@types/node": "^20.19.4",
    "@types/three": "^0.175.0",
    "@yushijinhun/three-minifier-rollup": "^0.4.0",
    "eslint": "^9.26.0",
    "eslint-plugin-svelte": "^3.5.1",
    "globals": "^16.1.0",
    "happy-dom": "^18.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.2.7",
    "rimraf": "^6.0.1",
    "svelte": "5.53.6",
    "svelte-check": "^4.3.1",
    "three": "^0.175.0",
    "tslib": "^2.6.2",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.32.0",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "mitt": "^3.0.1"
  },
  "peerDependencies": {
    "svelte": ">=5",
    "three": ">=0.160"
  },
  "type": "module",
  "keywords": [
    "svelte",
    "three",
    "three.js",
    "webgl",
    "webgpu",
    "webxr",
    "3d"
  ],
  "homepage": "https://threlte.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/threlte/threlte",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/threlte/threlte/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "types": "./dist/types.d.ts",
  "svelte": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite dev",
    "package": "svelte-kit sync && svelte-package && node ./scripts/cleanupPackage.js && publint",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "cleanup": "rimraf node_modules .svelte-kit dist"
  }
}